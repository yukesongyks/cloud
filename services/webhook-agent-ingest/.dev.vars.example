# Shared secrets (required for local dev — secrets store not available in wrangler dev)
# @from NEXTAUTH_SECRET
NEXTAUTH_SECRET=
# @from INTERNAL_API_SECRET
INTERNAL_API_SECRET=
# @from CALLBACK_TOKEN_SECRET
CALLBACK_TOKEN_SECRET=

# Worker environment
ENVIRONMENT=development

# Set your host/IP for local development callback URL
# @url cloudflare-webhook-agent-ingest
WEBHOOK_AGENT_URL=http://localhost:8793
