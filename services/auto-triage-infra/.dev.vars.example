# Backend API URL for status callbacks (configured in worker env, not passed in payload)
# @url nextjs
API_URL=http://localhost:3000

# Internal API secret for authentication (shared with backend)
# @from INTERNAL_API_SECRET
INTERNAL_API_SECRET=your-secret-here

# Backend auth token for authenticating incoming requests from backend
# @from AUTO_TRIAGE_AUTH_TOKEN
BACKEND_AUTH_TOKEN=your-backend-auth-token

# Cloud agent URL for triage execution
# @url cloud-agent-next
CLOUD_AGENT_URL=http://localhost:8794

# Public URL of this worker — used as the callback target for cloud-agent-next
# so it can POST terminal classification results back to us.
# For local dev this can be a public tunnel (e.g. ngrok) pointing at 8791.
SELF_URL=http://localhost:8791

# Environment configuration
ENVIRONMENT=development