{
  "name": "cloud-agent-next",
  "version": "1.0.0",
  "private": true,
  "description": "A Cloudflare Workers project for Kilocode Cloud Agents",
  "license": "MIT",
  "author": "",
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "deploy": "wrangler deploy",
    "predev": "pnpm run build:wrapper",
    "dev": "scripts/dev-with-docker-proxy.sh --env dev",
    "dev:no-proxy": "wrangler dev --env 'dev'",
    "dev:docker-proxy": "node scripts/docker-privileged-proxy.mjs",
    "prestart": "pnpm run build:wrapper",
    "start": "scripts/dev-with-docker-proxy.sh",
    "types": "wrangler types",
    "lint": "pnpm -w exec oxlint --config .oxlintrc.json services/cloud-agent-next/src services/cloud-agent-next/wrapper/src",
    "format": "oxfmt src",
    "format:check": "oxfmt --list-different src",
    "build:wrapper": "bun run --cwd wrapper build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.workers.config.ts",
    "test:integration:watch": "vitest --config vitest.workers.config.ts",
    "test:wrapper": "pnpm -C wrapper run test",
    "test:all": "vitest run && vitest run --config vitest.workers.config.ts && pnpm run test:wrapper",
    "typecheck": "tsgo --noEmit && pnpm -C wrapper run typecheck",
    "update-default-slash-commands": "node scripts/update-default-slash-commands.mjs"
  },
  "dependencies": {
    "@cloudflare/sandbox": "0.10.3",
    "@hono/trpc-server": "0.4.2",
    "@kilocode/cloud-agent-profile": "workspace:*",
    "@kilocode/db": "workspace:*",
    "@kilocode/encryption": "workspace:*",
    "@kilocode/notifications": "workspace:*",
    "@kilocode/worker-utils": "workspace:*",
    "@trpc/server": "catalog:",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "jsonc-parser": "3.3.1",
    "jsonwebtoken": "catalog:",
    "ulid": "catalog:",
    "workers-tagged-logger": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/containers": "0.3.5",
    "@cloudflare/vitest-pool-workers": "catalog:",
    "@types/jsonwebtoken": "catalog:",
    "@types/node": "catalog:",
    "@types/ws": "^8.5.12",
    "@typescript/native-preview": "catalog:",
    "@vitest/ui": "catalog:",
    "drizzle-kit": "catalog:",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "wrangler": "catalog:",
    "ws": "^8.18.0"
  }
}
