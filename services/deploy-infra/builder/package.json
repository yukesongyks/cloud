{
  "name": "kilo-deploy-builder",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "deploy": "wrangler deploy --outdir dist --upload-source-maps --var SENTRY_RELEASE:$(sentry-cli releases propose-version)",
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "test": "jest",
    "test-deploy": "tsx test-deploy.ts",
    "deploy:local": "tsx scripts/deploy-local.ts",
    "types": "wrangler types",
    "typecheck": "tsgo --noEmit",
    "lint": "pnpm -w exec oxlint --config .oxlintrc.json services/deploy-infra/builder/src",
    "sentry:sourcemaps": "_SENTRY_RELEASE=$(sentry-cli releases propose-version) && sentry-cli releases new $_SENTRY_RELEASE --org=kilo-code --project=kilocode-cloudflare-deploy && sentry-cli sourcemaps upload --org=kilo-code --project=kilocode-cloudflare-deploy --release=$_SENTRY_RELEASE --strip-prefix 'dist/..' dist",
    "postdeploy": "pnpm sentry:sourcemaps"
  },
  "dependencies": {
    "@kilocode/encryption": "workspace:*",
    "@kilocode/worker-utils": "workspace:*",
    "zod": "catalog:",
    "@sentry/cloudflare": "10.43.0",
    "hono": "catalog:",
    "tar-stream": "3.1.9"
  },
  "devDependencies": {
    "@cloudflare/sandbox": "0.6.11",
    "@cloudflare/workers-types": "catalog:",
    "@sentry/cli": "catalog:",
    "@types/jest": "29.5.14",
    "@types/node": "catalog:",
    "@types/tar-stream": "3.1.4",
    "@typescript/native-preview": "catalog:",
    "jest": "29.7.0",
    "ts-jest": "29.4.9",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "wrangler": "catalog:"
  }
}
