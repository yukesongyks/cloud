{
  "compilerOptions": {
    "target": "esnext",
    "lib": ["esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["@types/node", "./worker-configuration.d.ts"],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowJs": true,
    "resolveJsonModule": true
  },
  "include": [
    "worker-configuration.d.ts",
    "src/**/*.ts",
    "scripts/**/*.ts",
    "controller/src/**/*.ts",
    "vitest.config.ts",
    "drizzle/**/*"
  ]
}
