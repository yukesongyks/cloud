{
  "name": "cloud-agent",
  "version": "1.0.0",
  "private": true,
  "description": "A Cloudflare Workers project for Kilocode Cloud Agents",
  "license": "MIT",
  "author": "",
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "deploy": "wrangler deploy",
    "predev": "pnpm run build:wrapper",
    "dev": "wrangler dev --env 'dev'",
    "prestart": "pnpm run build:wrapper",
    "start": "wrangler dev",
    "types": "wrangler types",
    "lint": "pnpm -w exec oxlint --config .oxlintrc.json services/cloud-agent/src services/cloud-agent/wrapper/src",
    "format": "oxfmt src",
    "format:check": "oxfmt --list-different src",
    "build:wrapper": "bun run --cwd wrapper build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.workers.config.ts",
    "test:integration:watch": "vitest --config vitest.workers.config.ts",
    "test:all": "vitest run && vitest run --config vitest.workers.config.ts",
    "typecheck": "tsgo --noEmit && pnpm -C wrapper run typecheck"
  },
  "dependencies": {
    "@cloudflare/sandbox": "0.6.11",
    "@kilocode/db": "workspace:*",
    "@kilocode/encryption": "workspace:*",
    "@kilocode/worker-utils": "workspace:*",
    "@octokit/auth-app": "catalog:",
    "@trpc/server": "catalog:",
    "drizzle-orm": "catalog:",
    "jsonwebtoken": "catalog:",
    "workers-tagged-logger": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "catalog:",
    "@cloudflare/workers-types": "catalog:",
    "@types/jsonwebtoken": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitest/ui": "catalog:",
    "drizzle-kit": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  }
}
