{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@/types/*": ["../../apps/web/src/types/*"],
      "@/lib/cloud-agent-next/*": ["../../apps/web/src/lib/cloud-agent-next/*"],
      "@/lib/cloud-agent/constants": ["../../apps/web/src/lib/cloud-agent/constants.ts"],
      "@/lib/images-schema": ["../../apps/web/src/lib/images-schema.ts"],
      "@/*": ["./src/*"],
      "@/assets/*": ["./assets/*"],
      "cloud-agent-sdk": ["../../apps/web/src/lib/cloud-agent-sdk/index.ts"],
      "cloud-agent-sdk/*": ["../../apps/web/src/lib/cloud-agent-sdk/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts", "nativewind-env.d.ts"]
}
