{
  "name": "kilo-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "build": "pnpx eas-cli@latest build --profile development",
    "build:ios": "pnpx eas-cli@latest build -p ios --profile development",
    "build:android": "pnpx eas-cli@latest build -p android --profile development",
    "release:internal": "pnpx eas-cli@latest build --profile production --submit",
    "release:internal:ios": "pnpx eas-cli@latest build -p ios --profile production --submit",
    "release:internal:android": "pnpx eas-cli@latest build -p android --profile production --submit",
    "typecheck": "tsgo --noEmit",
    "lint": "pnpm -w exec oxlint --config apps/mobile/.oxlintrc.json apps/mobile/src",
    "format": "oxfmt src",
    "format:check": "oxfmt --list-different src",
    "check:unused": "node --env-file=.env node_modules/knip/bin/knip.js --no-config-hints",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@expo-google-fonts/jetbrains-mono": "0.4.1",
    "@expo/react-native-action-sheet": "4.1.1",
    "@kilocode/event-service": "workspace:*",
    "@kilocode/kilo-chat": "workspace:*",
    "@kilocode/kilo-chat-hooks": "workspace:*",
    "@kilocode/notifications": "workspace:*",
    "@kilocode/trpc": "workspace:*",
    "@react-native-community/netinfo": "11.5.2",
    "@rn-primitives/portal": "1.3.0",
    "@rn-primitives/slot": "1.2.0",
    "@sentry/react-native": "~7.11.0",
    "@shopify/flash-list": "2.0.2",
    "@tailwindcss/postcss": "4.2.4",
    "@tanstack/react-query": "catalog:",
    "@trpc/client": "catalog:",
    "@trpc/tanstack-react-query": "catalog:",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "expo": "55.0.24",
    "expo-apple-authentication": "55.0.13",
    "expo-application": "55.0.15",
    "expo-blur": "55.0.14",
    "expo-build-properties": "55.0.14",
    "expo-clipboard": "55.0.13",
    "expo-constants": "55.0.16",
    "expo-crypto": "55.0.15",
    "expo-dev-client": "~55.0.34",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "55.0.20",
    "expo-font": "55.0.7",
    "expo-haptics": "55.0.14",
    "expo-iap": "4.2.8",
    "expo-image": "55.0.10",
    "expo-image-picker": "~55.0.20",
    "expo-insights": "55.0.17",
    "expo-linking": "55.0.15",
    "expo-location": "55.1.10",
    "expo-notifications": "55.0.23",
    "expo-router": "55.0.14",
    "expo-screen-corner-radius": "^1.0.1",
    "expo-secure-store": "55.0.14",
    "expo-sharing": "~55.0.19",
    "expo-splash-screen": "55.0.21",
    "expo-status-bar": "55.0.6",
    "expo-tracking-transparency": "55.0.14",
    "expo-web-browser": "55.0.16",
    "jotai": "2.18.1",
    "lucide-react-native": "1.7.0",
    "nativewind": "5.0.0-preview.3",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-appsflyer": "6.17.9",
    "react-native-css": "3.0.7",
    "react-native-gesture-handler": "2.30.1",
    "react-native-marked": "8.0.1",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-worklets": "0.7.4",
    "sonner-native": "0.23.1",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.4",
    "ulid": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@sentry/cli": "catalog:",
    "@types/react": "19.2.14",
    "@typescript/native-preview": "catalog:",
    "eslint-plugin-sonarjs": "4.0.3",
    "knip": "6.0.6",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "dependenciesMeta": {
    "@kilocode/kilo-chat-hooks": {
      "injected": true
    }
  },
  "expo": {
    "install": {
      "exclude": []
    }
  },
  "private": true
}
