{
  "compilerOptions": {
    "target": "es2017",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["dom", "dom.iterable", "esnext", "esnext.asynciterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@/*": ["./src/*"],
      "@kilocode/db": ["../../packages/db/src/index.ts"],
      "@kilocode/db/*": ["../../packages/db/src/*"],
      "@kilocode/cloud-agent-profile": ["../../packages/cloud-agent-profile/src/index.ts"],
      "@kilocode/encryption": ["../../packages/encryption/src/index.ts"],
      "@kilocode/worker-utils": ["../../packages/worker-utils/src/index.ts"],
      "@kilocode/worker-utils/*": ["../../packages/worker-utils/src/*"],
      "@cloud-agent-shared": ["../../services/cloud-agent-next/src/shared/slash-commands.ts"],
      "@cloud-agent-shared/*": ["../../services/cloud-agent-next/src/shared/*"]
    },
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "typeRoots": ["./node_modules/@types"],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictPropertyInitialization": false,
    "noErrorTruncation": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "next-env.d.ts",
    "src/**/*",
    "tests/**/*",
    ".next/types/**/*.ts",
    "jest.config.ts",
    "knip.ts",
    "instrumentation-client.ts",
    "sentry.edge.config.ts",
    "sentry.server.config.ts",
    ".next/dev/types/**/*.ts",
    "dev/discord-gateway-cron.ts"
  ],
  "exclude": ["node_modules", ".next"]
}
